# =============================================================================
# GAIOL App Environment (web server / tenant-facing API)
# =============================================================================
# Copy to .env and fill in values. Provider keys (OpenRouter, Gemini, HuggingFace)
# are NOT set here: users add them in the dashboard; the app loads them from
# the database per tenant.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for auth and database)
# -----------------------------------------------------------------------------
# From Supabase Dashboard: Settings > API > Project URL and anon/public key

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key-here

# Alternative names (optional)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Server-side JWT secret (for verifying Supabase auth tokens)
# From Supabase Dashboard: Settings > API > JWT secret
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Encryption (for stored provider keys)
# -----------------------------------------------------------------------------
# 32-byte hex key used to encrypt provider API keys at rest. Generate with:
#   openssl rand -hex 32
GAIOL_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Server (optional)
# -----------------------------------------------------------------------------
# PORT=8080

# -----------------------------------------------------------------------------
# Production (optional)
# -----------------------------------------------------------------------------
# Comma-separated CORS origins (e.g. https://app.example.com). Leave unset for *.
# ALLOWED_ORIGINS=https://your-domain.com

# Public URL of the Go web server (no trailing slash). Required for Vercel static deploys:
# set the same name in Vercel Project → Settings → Environment Variables so the build injects web/js/gaiol-api-config.js.
# GAIOL_API_PUBLIC_URL=https://your-go-api.fly.dev

# Log level: debug, info, warn, error (default info). debug logs every request.
# LOG_LEVEL=info

# =============================================================================
# CLI / benchmark only (not used by the app server)
# =============================================================================
# For cmd/benchmark, cmd/paper-metrics, or local eval. The web server never
# reads these; tenant inference uses keys from the database only.
#
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# HUGGINGFACE_API_KEY=
# =============================================================================
