# =============================================================================
# GAIOL Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual credentials
# 
#   Windows: copy .env.example .env
#   Linux/Mac: cp .env.example .env
#   Then edit .env with your actual API keys
#
# =============================================================================

# -----------------------------------------------------------------------------
# AI Provider API Keys
# -----------------------------------------------------------------------------

# OpenRouter API Key (REQUIRED)
# Get your key from: https://openrouter.ai/keys
# This is required for most AI models to work
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Google Gemini API Key (OPTIONAL)
# Get your key from: https://makersuite.google.com/app/apikey
# Enables access to Google Gemini models
# GEMINI_API_KEY=your-gemini-api-key-here

# HuggingFace API Key (OPTIONAL)
# Get your key from: https://huggingface.co/settings/tokens
# Enables access to HuggingFace models
# HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# -----------------------------------------------------------------------------
# Supabase Database Configuration (REQUIRED for authentication)
# -----------------------------------------------------------------------------
# Get these from your Supabase project dashboard: https://supabase.com
# Go to: Settings > API > Project URL and anon/public key
#
# Without these, the server will run but authentication features will be disabled

# Supabase Project URL
# Format: https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon/Public Key
# This is the publishable anon key (safe for client-side use)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key-here

# Alternative Supabase variable names (for compatibility with other tools)
# You can use these instead of or in addition to the NEXT_PUBLIC_* variables
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# -----------------------------------------------------------------------------
# Server Configuration (OPTIONAL)
# -----------------------------------------------------------------------------

# Server Port (defaults to 8080 if not set)
# PORT=8080

# =============================================================================
# Notes:
# =============================================================================
# - Never commit your .env file to version control (it's in .gitignore)
# - Keep your API keys secure and never share them publicly
# - The .env file is automatically loaded by the application
# - You can also set these as system environment variables instead
# =============================================================================
