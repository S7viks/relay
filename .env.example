# =============================================================================
# GAIOL App Environment (web server / tenant-facing API)
# =============================================================================
# Copy to .env and fill in values. Provider keys (OpenRouter, Gemini, HuggingFace)
# are NOT set here: users add them in the dashboard; the app loads them from
# the database per tenant.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for auth and database)
# -----------------------------------------------------------------------------
# From Supabase Dashboard: Settings > API > Project URL and anon/public key

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key-here

# Alternative names (optional)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Go server only — PostgREST tenant tables under RLS (never put in frontend / Vite env)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server-side JWT secret (for verifying Supabase auth tokens)
# From Supabase Dashboard: Settings > API > JWT secret
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Encryption (for stored provider keys)
# -----------------------------------------------------------------------------
# 32-byte hex key used to encrypt provider API keys at rest. Generate with:
#   openssl rand -hex 32
GAIOL_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Server (optional)
# -----------------------------------------------------------------------------
# PORT=8080

# -----------------------------------------------------------------------------
# Local dev only (omit for real auth + database)
# -----------------------------------------------------------------------------
# If set truthy (1/true/on), the Go server skips Supabase and uses env provider keys.
# Remove or comment out for production-style auth and tenant DB (requires SUPABASE_* + service role).
# GAIOL_DISABLE_AUTH=1

# -----------------------------------------------------------------------------
# Production (optional)
# -----------------------------------------------------------------------------
# Comma-separated CORS origins (exact match, no trailing slash). Required when locking down CORS:
# the browser Origin must appear in this list or credentialed fetches get no Allow-Origin header.
# Vercel dashboard + Render API: set the same value on Render (Environment), e.g.
# ALLOWED_ORIGINS=https://gaiol.vercel.app
# ALLOWED_ORIGINS=https://your-domain.com

# Browser API origin when the React app is hosted separately (no trailing slash).
# Set on Vercel for `dashboard` builds: VITE_API_BASE=https://your-go-api.fly.dev
# Optional legacy inject script output: GAIOL_API_PUBLIC_URL (see scripts/inject-gaiol-config.js).
# VITE_API_BASE=https://your-go-api.fly.dev

# Log level: debug, info, warn, error (default info). debug logs every request.
# LOG_LEVEL=info

# =============================================================================
# CLI / benchmark only (not used by the app server)
# =============================================================================
# For cmd/benchmark, cmd/paper-metrics, or local eval. The web server never
# reads these; tenant inference uses keys from the database only.
#
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# HUGGINGFACE_API_KEY=
#
# TypeScript orchestrator (cd orchestrator && npm run dev:api) uses:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=   (Gemini; optional third provider)
# Optional model IDs (defaults shown):
# OPENAI_ORCHESTRATOR_MODEL=gpt-4o-mini
# ANTHROPIC_ORCHESTRATOR_MODEL=claude-3-5-haiku-20241022
# GEMINI_ORCHESTRATOR_MODEL=gemini-2.0-flash
# OPENAI_BASE_URL=  (OpenAI-compatible proxy, optional)
# =============================================================================
