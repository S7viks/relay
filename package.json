{
  "name": "gaiol",
  "private": true,
  "description": "Root package: optional inject script for dashboard/public/gaiol-api-config.js. Vercel builds dashboard/ via vercel.json; prefer VITE_API_BASE for the React SPA.",
  "scripts": {
    "build": "node scripts/inject-gaiol-config.js",
    "benchmark": "npx tsx scripts/benchmark/run_benchmark.ts",
    "benchmark:sweeps": "npx tsx scripts/benchmark/run_benchmark.ts --sweeps-only",
    "benchmark:convergence": "npx tsx scripts/benchmark/run_benchmark.ts --convergence",
    "benchmark:cumulative": "npx tsx scripts/benchmark/run_benchmark.ts --cumulative",
    "inject-results": "npx tsx scripts/benchmark/inject_results.ts"
  }
}
