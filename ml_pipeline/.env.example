# Required for Sys-2 (direct OpenAI) and Sys-3 (LangChain) baselines
OPENAI_API_KEY=

# Required for Sys-4, Sys-5 (OpenRouter baselines) and as fallback for Sys-2/Sys-3
OPENROUTER_API_KEY=

# Optional: Google Gemini baseline (if enabled in runner)
GOOGLE_API_KEY=

# GAIOL orchestrator (Sys-1 runner)
GAIOL_ORCHESTRATOR_URL=http://localhost:3001

# LLM-as-judge model for quality_evaluator.py (default: gpt-4)
EVAL_MODEL=gpt-4

# Secondary evaluator (Gemini) for inter-evaluator agreement
EVAL_MODEL_GEMINI=gemini-1.5-flash
