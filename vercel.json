{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo install skipped",
  "buildCommand": "npm run build",
  "outputDirectory": "web",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/dashboard/:path*", "destination": "/dashboard.html" }
  ]
}
