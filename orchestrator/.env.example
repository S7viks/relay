# API
ORCHESTRATOR_PORT=8787
LOG_LEVEL=info

# Provider API keys (enable any combination; orchestrator registers all configured providers)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://gaiol.local
OPENROUTER_APP_TITLE=GAIOL
HUGGINGFACE_API_KEY=
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

# Optional per-provider default model (others use built-in catalog)
# OPENAI_ORCHESTRATOR_MODEL=gpt-4o-mini
# ANTHROPIC_ORCHESTRATOR_MODEL=claude-3-5-haiku-20241022
# GEMINI_ORCHESTRATOR_MODEL=gemini-2.0-flash
# GROQ_ORCHESTRATOR_MODEL=llama-3.1-8b-instant

# Persistence (optional file-backed trust / traces)
GAIOL_DATA_DIR=./data

# Budget defaults (orchestrator enforces per-request caps)
DEFAULT_MAX_COST_USD=1.0
DEFAULT_MAX_LATENCY_MS_PER_CALL=120000
DEFAULT_MAX_PARALLEL_CALLS=8
