{
  "name": "@gaiol/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:api": "tsx --env-file=../.env src/api/server.ts",
    "start": "tsx --env-file=../.env src/api/server.ts",
    "cli": "tsx --env-file=../.env src/cli/index.ts",
    "benchmark": "tsx ../scripts/benchmark/run_benchmark.ts",
    "benchmark:sweeps": "tsx ../scripts/benchmark/run_benchmark.ts --sweeps-only",
    "benchmark:convergence": "tsx ../scripts/benchmark/run_benchmark.ts --convergence",
    "benchmark:cumulative": "tsx ../scripts/benchmark/run_benchmark.ts --cumulative"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.17.1",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
